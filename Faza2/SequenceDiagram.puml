@enduml

@startuml ADD_PRODUCT
actor "Manager" as M
participant "a: Alert" as A <<boundary>>
participant "aW: addWindow" as AW <<boundary>>
participant "s: service" as S <<control>>
participant "pR: productRepo" as R <<boundary>>
database "SGBD" as DB
M --> AW : 1: <<create>>
M -> AW : 2: name = insertName() : String
activate AW
M -> AW : 3: price = insertPrice() : String
M -> AW : 4: imageURL = insertImageURL() : String
M -> AW : 5: ttl = insertTTL() : String
M -> AW : 6: clickSave()
AW -> S : 7: saveProduct(name, price, imageURL, ttl) : Product
activate S
S -> R : 8: save(name, price, imageURL, ttl)
activate R
R -> DB : 9: INSERT INTO
activate DB
DB --> R : 10: b = true / false
deactivate DB
R -> S : 11 : b = true / false
deactivate R
S -> AW : 12 : b = true / false
deactivate S
AW --> A : 13: <<create>>
alt b == true
    AW -> A : 14: showAlert("Successful operation")
    activate A
    deactivate A
else b == false
    AW -> A : 15: showAlert("Error occurred")
    activate A
    deactivate A
end
@enduml

@startuml UPDATE_QUANTITY
actor "Manager" as M
participant "mW: mainWindow" as MW <<boundary>>
participant "a: Alert" as A <<boundary>>
participant "sW: stockWindow" as SW <<boundary>>
participant "s: Service" as S <<control>>
participant "pR: ProductRepo" as PR <<boundary>>
participant "bR: BatchItemRepo" as BR <<boundary>>
database "SGBD" as DB
M -> MW : 0: showStockWindow()
activate MW
MW --> SW : 1: stockWindow(s)<<create>>
MW -> SW : 2: show()
activate SW
MW -> MW : hide()
deactivate MW
SW -> S : 3:  products = getAllProducts() : List<Product>
activate S
S -> PR : 4: products = findAll() : List<Product>
activate PR
PR -> DB : 5: SELECT FROM
activate DB
DB --> PR : 6: products
deactivate DB
PR -> S : 7: products
deactivate PR
S -> SW : 8: products
deactivate S
M -> SW : 9: clicks a button
SW -> S : 10: onBtnClick(productId : Long, quantity : Long)
activate S
S -> BR : 11: addBatch(productId : Long, quantity : Long, TTL : Long)
activate BR
BR --> S : 12: b = true / false
deactivate BR
S --> SW : 13: b = true / false
deactivate S
alt b == true
    SW --> A : 14: <<create>>
    SW -> A : 15: showAlert("operation successful")
    activate A
    deactivate A
else b == false
SW -> A : 16: showAlert("error occurred")
activate A
deactivate A
end
@enduml