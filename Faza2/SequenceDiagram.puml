@startuml CUSTOMER_LOGIN
actor "Customer" as C
participant "MainClass" as Main <<boundary>>
participant "mM: ManagerMainPage" as mMain <<boundary>>
participant "a: AlertBox" as alert <<boundary>>
participant "lW: LoginWindow" as LW <<boundary>>
participant "s: Service" as S <<control>>
participant "uR: UserRepo" as R <<repository>>
database "SGBD" as DB
C -> Main : 1: main()
activate Main
Main --> R : 2: uR = UserRepo() <<create>>
Main --> S : 3: s = Service(uR) <<create>>
Main --> LW : 4: LoginWindow(s) <<create>>
Main -> LW : 5: show()
activate LW
deactivate Main
C -> LW : 6: username = insertUsername() : String
C -> LW : 7: password = insertPassword() : String
C -> LW : 8: onLogIn()
LW -> S : 9: c = login(username, password) : Manager
activate S
S -> R : 10: u = findOne(username, password) : User
activate R
R -> DB : 11: SELECT SQL
activate DB
DB --> R : 12: user / null
deactivate DB
R --> S : 13: user / null
deactivate R
S --> LW : 14: c / null
deactivate S
alt c != null
    LW --> mMain : 15: managerMainWindow(s, c) <<create>>
    LW -> mMain : 16: show()
    activate mMain
    deactivate mMain
    LW --> LW : 17: hide()
else c == null
    LW --> alert : 18: <<create>>
    activate alert
    LW -> alert : 19: showAlert("Invalid credentials")
    deactivate alert
end
@enduml

@startuml MANAGER_LOGIN
