Main -> LW : 5: show()
activate LW
deactivate Main
M -> LW : 6: username = insertUsername() : String
M -> LW : 7: password = insertPassword() : String
M -> LW : 8: onLogIn()
LW -> S : 9: m = login(username, password) : Manager
activate S
S -> R : 10: u = findOne(username, password) : User
activate R
R -> DB : 11: SELECT SQL
activate DB
DB --> R : 12: user / null
deactivate DB
R --> S : 13: user / null
deactivate R
S --> LW : 14: m / null
