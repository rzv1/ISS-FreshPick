@startuml ADD_PRODUCT_TO_CART
actor "Customer" as C
participant "mW: mainWindow" as M <<boundary>>
participant "a: Alert" as A <<boundary>>
participant "s: Service" as S <<control>>
participant "bR: batchRepo" as BR <<boundary>>
participant "cR: cartRepo" as R <<boundary>>
database "SGBD" as DB

C -> M : 1: clickOnAddToCart()
activate M
M -> S : 2: addCartItem(batchID, productName, price)
activate S
S -> BR : 3: findOne(batchID : Long)
activate BR
BR -> DB : 4: SELECT FROM
activate DB
DB --> BR : 5: BatchItem / null
deactivate DB
BR --> S : 4: BatchItem / null
deactivate BR
alt batch == null
    S --> M : 5: null
    M --> A : 6: <<create>>
    M -> A : 7: showAlert("stock changed")
    activate A
    deactivate A
else batch != null
    S -> R : 8: saveItem(item : cartItem)
    activate R
    R -> DB : 8: INSERT INTO
    activate DB
    DB --> R : 9: true
    deactivate DB
    R --> S : 10: true
    deactivate R
    S --> M : 11: true
    deactivate S
    M --> A : 12: <<create>>
    M -> A : 13: showAlert("item added")
    activate A
    deactivate A
end
@enduml

@startuml CHANGE_CART_PRODUCT_QUANTITY
actor "Customer" as C
participant "mW: mainWindow" as M <<boundary>>
participant "cW: cartWindow" as CW <<boundary>>
participant "s: Service" as S <<control>>
participant "cR: cartItemRepo" as R <<boundary>>
database "SGBD" as DB
C -> M: 1: onCartClick()
activate M
M --> CW: 2: cartWindow(u, s) <<create>>
M -> CW: 3: show()
activate CW
M -> M: 4: hide()
deactivate M
alt
C -> CW: 5: onPlusClick(itemId : Long)
CW -> S: 6: increaseItemQuantity(itemId : Long)
activate S
S -> R: 7: increaseItemQuantity(itemId : Long)
activate R
R -> DB: 8: UPDATE SET WHERE
activate DB
DB --> R: 9: cartItem
deactivate DB
R --> S: 10: cartItem
deactivate R
S --> CW: 11: cartItem
deactivate S
else
C -> CW: 5: onMinusClick(itemId : Long)
CW -> S: 6: decreaseItemQuantity(itemId : Long)
activate S
S -> R: 7: decreaseItemQuantity(itemId : Long)
activate R
R -> DB: 8: UPDATE SET WHERE
activate DB
DB --> R: 9: cartItem
deactivate DB
R --> S: 10: cartItem
deactivate R
S --> CW: 11: cartItem
deactivate S
deactivate CW
end
@enduml

