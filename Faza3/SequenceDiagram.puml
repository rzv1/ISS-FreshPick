@startuml FINALIZE_ORDER
actor "Customer" as C
participant "cW: cartWindow" as CW <<boundary>>
participant "a: Alarm" as A <<boundary>>
participant "s: Service" as S <<control>>
participant "iR: cartItemRepo" as CR <<boundary>>
participant "bR: batchItemRepo" as BR <<boundary>>
participant "oR: orderRepo" as OR <<boundary>>
database "SGBD" as DB

C -> CW: 1: pressFinalizeButton()
activate CW
CW -> S: 2: onFinalize()
activate S
S -> CR: 3: findAllForUser(userId : Long)
activate CR
CR -> DB: 4: SELECT FROM
activate DB
DB --> CR: 5: List<CartItem>
deactivate DB
CR --> S: 6: List<CartItem>
deactivate CR
loop for each cartItem
    S -> BR: 7: checkStock(batchId, quantity)
    activate BR
    BR -> DB: 8: SELECT FROM
    activate DB
    DB --> BR: 9: item / null
    deactivate DB
    BR --> S: 10: isAvailable
    deactivate BR

    alt isAvailable == false
        S --> A : showMessage("Stoc insuficient")
        activate A
        deactivate A
    end
end
S -> OR: 11: save(userId, cartItems)
activate OR
OR --> S: 12: orderId
deactivate OR

loop for each cartItem
   S -> BR: 13: decrementStock(batchId, quantity)
   activate BR
   deactivate BR
   S -> CR: 14: delete(cartItemId)
   activate CR
   deactivate CR
end
S --> A: showMessage(orderId)
deactivate S
@enduml

