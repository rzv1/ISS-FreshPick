@startuml VIEW_STOCK
actor "Manager" as M
participant "mW: MainWindow" as MW <<boundary>>
participant "iW: inventoryWindow" as IW <<boundary>>
participant "s: Service" as S <<control>>
participant "bR: batchItemRepo" as BR <<boundary>>
database "SGBD" as DB

M -> MW : 1: onDashboardClick()
activate MW
MW --> IW : 2: inventoryWindow(s) <<create>>
MW -> IW : 3: view()
activate IW
MW --> MW : 4: hide()
deactivate MW
IW -> S : 5: getAllInventory()
activate S
S -> BR : 6: findAll()
activate BR
BR -> DB : 7: SELECT FROM
activate DB
DB --> BR : 8: List<BatchItem>
deactivate DB
BR --> S : 9: List<BatchItem>
deactivate BR
S --> IW : 10: InventoryDTO
deactivate S
deactivate IW
@enduml

@startuml REMOVE_PRODUCT
actor "Manager" as M
participant "a: Alert" as A <<boundary>>
participant "iW: inventoryWindow" as IW <<boundary>>
participant "s: Service" as S <<control>>
participant "bR: batchItemRepo" as BR <<boundary>>
database "SGBD" as DB

M -> IW : 1: onDeleteClick(batchItemID : Long)
activate IW
IW -> S : 2: deleteBatch(batchItemID : Long)
activate S
S -> BR : 3: delete(batchItemID : Long)
activate BR
BR -> DB : 4: DELETE FROM
activate DB
DB --> BR : 5: c = true / false
deactivate DB
BR --> S : 6: c = true / false
deactivate BR
S --> IW : 7: c = true / false
deactivate S
alt c == false
   IW --> A : 8: <<create>>
   IW -> A : 9: showAlert("error occurred")
   activate A
   deactivate A
else c == true
    IW -> S : 10: getAllInventory()
    activate S
    S -> BR : 11: findAll()
    activate BR
    BR -> DB : 12: SELECT FROM
    activate DB
    DB --> BR : 13: List<BatchItem>
    deactivate DB
    BR --> S : 14: List<BatchItem>
    deactivate BR
    S --> IW : 15: InventoryDTO
    deactivate S
    deactivate IW
end
@enduml

